{"id": "151-1724-244-249", "original": "Lokā vivaṭṭantīti– lokuttarā . ", "content": "「他們從世間(Lokā)轉回」為出世間；"}
{"id": "151-1724-250-254", "original": "Lokato vivaṭṭantīti– lokuttarā. ", "content": "「他們從世間(Lokato)轉回」為出世間；"}
{"id": "151-1724-255-259", "original": "Lokamhā vivaṭṭantīti– lokuttarā. ", "content": "「他們從世間(Lokamhā)轉回」為出世間；"}
{"id": "151-1724-260-265", "original": "Loke na sajjantīti– lokuttarā. ", "content": "「他們在世間中不黏著」為出世間；"}
{"id": "151-1724-266-271", "original": "Loke na gayhantīti– lokuttarā. ", "content": "「他們在世間中不被抓住」為出世間；"}
{"id": "151-1724-272-277", "original": "Loke na bajjhantīti– lokuttarā. ", "content": "「他們在世間中不被縛結」為出世間；"}
{"id": "151-1724-278-282", "original": "Lokaṃ samucchindantīti– lokuttarā. ", "content": "「他們斷絕世間」為出世間；"}
{"id": "151-1724-283-287", "original": "Lokaṃ samucchinnattāti– lokuttarā. ", "content": "「為斷絕世間的狀態者」為出世間；"}
{"id": "151-1724-288-293", "original": "Lokaṃ paṭippassambhentīti– lokuttarā. ", "content": "「他們使世間止息」為出世間；"}
{"id": "151-1724-294-298", "original": "Lokaṃ paṭippassambhitattāti– lokuttarā. ", "content": "「為止息世間的狀態者」為出世間；"}
{"id": "151-1724-299-303", "original": "Lokassa apathāti– lokuttarā. ", "content": "「不屬於世間道」為出世間；"}
{"id": "151-1724-304-308", "original": "Lokassa agatīti– lokuttarā. ", "content": "「不屬於世間趣處」為出世間；"}
{"id": "151-1724-309-313", "original": "Lokassa avisayāti– lokuttarā. ", "content": "「不屬於世間對象(對境)」為出世間；"}
{"id": "151-1724-314-318", "original": "Lokassa asādhāraṇāti– lokuttarā. ", "content": "「不屬於世間共通的」為出世間；"}
{"id": "151-1724-319-323", "original": "Lokaṃ vamantīti– lokuttarā. ", "content": "「他們吐出世間」為出世間；"}
{"id": "151-1724-324-329", "original": "Lokaṃ na paccāvamantīti– lokuttarā. ", "content": "「他們{{note|trigger=不再吞回|text=「不再吞回」(na paccāvamantīti, na pati+avamati, 再+吞回/吞下吐出的東西)，《顯揚正法》以「已吐出的不再吃入」(vantaṃ puna na adantīti)解說。}}世間」為出世間；"}
{"id": "151-1724-330-334", "original": "Lokaṃ pajahantīti– lokuttarā. ", "content": "「他們捨斷世間」為出世間；"}
{"id": "151-1724-335-340", "original": "Lokaṃ na upādiyantīti– lokuttarā. ", "content": "「他們不執取世間」為出世間；"}
{"id": "151-1724-341-345", "original": "Lokaṃ visinentīti– lokuttarā. ", "content": "「他們驅散世間」為出世間；"}
{"id": "151-1724-346-351", "original": "Lokaṃ na ussinentīti– lokuttarā. ", "content": "「他們不積聚世間」為出世間；"}
{"id": "151-1724-352-356", "original": "Lokaṃ vidhūpentīti– lokuttarā. ", "content": "「他們熄滅世間」為出世間；"}
{"id": "151-1724-357-362", "original": "Lokaṃ na saṃdhūpentīti– lokuttarā. ", "content": "「他們不點燃世間」為出世間；"}
{"id": "151-1724-363-369", "original": "Lokaṃ samatikkamma abhibhuyya tiṭṭhantīti– lokuttarā. ", "content": "「他們超越、征服世間後住立」為出世間。"}
{"id": "151-1725-2-4", "original": "Lokuttarakathā niṭṭhitā.", "content": "出世間的談論終了。"}
